<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" style="-fx-background-color: transparent;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.controller.AuctionListController">

    <children>
        <Label text="Danh sách phiên đấu giá" textFill="WHITE">
            <font> <Font name="System Bold" size="24.0" /> </font>
        </Label>

        <TableView fx:id="tblAuctions" style="-fx-background-color: #1E293B; -fx-control-inner-background: #1E293B;" styleClass="custom-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="419.0" text="Mã phiên (ID)" />
                <TableColumn fx:id="colStatus" prefWidth="181.0" text="Trạng thái phiên" />
            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>

    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="10.0" />
    </padding>
</VBox>
